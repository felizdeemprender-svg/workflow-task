rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }

    // Get company ID helper (direct token check or fallback)
    function getCompanyId() {
      return request.auth.token.company_id != null ? 
             request.auth.token.company_id : 
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.company_id : 
              null);
    }

    // Get user role helper
    function getRole() {
      return request.auth.token.role != null ? 
             request.auth.token.role : 
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : 
              'Empleado');
    }

    function isCEO() {
      return request.auth.token.email == 'felizdeemprender@gmail.com' || getRole() == 'CEO';
    }

    function isAdmin() {
      return getRole() == 'Admin';
    }

    // --- Collections ---

    // Users: Employees read colleagues. Admins/CEOs manage.
    match /users/{userId} {
      allow get: if isAuthenticated() && (request.auth.uid == userId || isCEO());
      allow list: if isAuthenticated(); // Allow queries on users collection
      
      // Temporary: Allow full read for authenticated users to avoid permission race conditions
      allow read: if isAuthenticated();

      allow write: if isAuthenticated() && (
        request.auth.uid == userId || 
        isCEO() || 
        (isAdmin() && (
          (resource == null && request.resource.data.company_id == getCompanyId()) ||
          (resource != null && resource.data.company_id == getCompanyId())
        ))
      );

      match /spirit_history/{historyId} {
        allow read: if isAuthenticated() && (request.auth.uid == userId || isCEO());
      }
    }

    // Companies: Setup mode
    match /companies/{companyId} {
      allow read: if isAuthenticated() && (isCEO() || getCompanyId() == companyId);
      allow update: if isAuthenticated() && (isCEO() || (isAdmin() && getCompanyId() == companyId));
      allow create: if isAuthenticated(); 
    }

    // Tasks: Filtered by company.
    match /tasks/{taskId} {
      allow read, update: if isAuthenticated() && (isCEO() || getCompanyId() == resource.data.company_id);
      allow create: if isAuthenticated() && (isCEO() || getCompanyId() == request.resource.data.company_id);

      match /{allSubcollections=**} {
        allow read, write: if isAuthenticated() && (
          isCEO() || 
          getCompanyId() == get(/databases/$(database)/documents/tasks/$(taskId)).data.company_id
        );
      }
    }

    match /polls/{pollId} {
      allow read: if isAuthenticated() && (isCEO() || getCompanyId() == resource.data.company_id);
      allow create: if isAuthenticated() && (isCEO() || (getCompanyId() != null && getCompanyId() == request.resource.data.company_id));
      allow update: if isAuthenticated() && (isCEO() || (getCompanyId() != null && getCompanyId() == resource.data.company_id));
    }

    // Notifications: Owner only for read/delete.
    match /notifications/{notificationId} {
      allow read, update, delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isCEO()
      );
      allow create: if isAuthenticated();
    }

    // Notebook: Personal notes.
    match /notebook_entries/{noteId} {
      allow read, write, delete: if isAuthenticated() && (
        isCEO() || 
        (resource == null && request.resource.data.user_id == request.auth.uid) ||
        (resource != null && resource.data.user_id == request.auth.uid)
      );
    }

    match /notebook_drafts/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isCEO());
    }

    // Chats: Direct messages between team members.
    match /chats/{chatId} {
      allow read: if isAuthenticated() && (
        isCEO() || 
        request.auth.uid in resource.data.participants
      );
      allow write: if isAuthenticated() && (
        isCEO() || 
        (
          request.auth.uid in request.resource.data.participants &&
          getCompanyId() == request.resource.data.company_id
        )
      );

      match /messages/{messageId} {
        allow read, create: if isAuthenticated() && (
          isCEO() || 
          chatId.split('_')[0] == request.auth.uid || 
          chatId.split('_')[1] == request.auth.uid
        );
      }
    }
  }
}
